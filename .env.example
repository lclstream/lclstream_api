# lclstream_api configuration
# Copy to .env and adjust. Comma-separated fields accept "a,b,c" or a JSON list.

# --- App (LCLSTREAM_APP_*) -------------------------------------------------
# External path prefix the app is mounted under (FastAPI root_path). Must match
# the gateway's PathPrefix; override per env (e.g. /api/dev).
LCLSTREAM_APP_ROOT_PATH=/api/v2

# --- Inbound auth: user OIDC JWT (LCLSTREAM_OIDC_*) -------------------------
LCLSTREAM_OIDC_ISSUER_URL=https://dex.slac.stanford.edu
LCLSTREAM_OIDC_JWKS_URI=https://dex.slac.stanford.edu/keys
LCLSTREAM_OIDC_AUDIENCES=s3df
# Verified emails allowed to use the service (allowlist; all members see all).
LCLSTREAM_OIDC_EXPECTED_USERS=user1@slac.stanford.edu,user2@slac.stanford.edu

# --- IRI / S3DF (LCLSTREAM_IRI_*) ------------------------------------------
LCLSTREAM_IRI_BASE_URL=https://iri.slac.stanford.edu
# REQUIRED: shared 12h SLAC bearer token, mounted from s3df.
LCLSTREAM_IRI_S3DF_TOKEN_FILE=/secrets/s3df_token

# --- fastcache_api (LCLSTREAM_FASTCACHE_*) ---------------------------------
LCLSTREAM_FASTCACHE_BASE_URL=https://sdfdtn003.sdf.slac.stanford.edu:8000
# REQUIRED: same shared token file as IRI (re-read each request on rotation).
LCLSTREAM_FASTCACHE_TOKEN_FILE=/secrets/s3df_token
# REQUIRED mTLS: client cert/key + CA bundle that signs the fastcache server cert.
LCLSTREAM_FASTCACHE_CLIENT_CERT=/secrets/certs/client.crt
LCLSTREAM_FASTCACHE_CLIENT_KEY=/secrets/certs/client.key
LCLSTREAM_FASTCACHE_VERIFY=/secrets/certs/ca.crt
